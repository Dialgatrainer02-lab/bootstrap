#cloud-config
merge_how:
  - name: list
    settings: [append]
  - name: dict
    settings: [no_replace, recurse_list]

write_files:
  - path: /etc/hosts
    permissions: "0644"
    append: true
    content: |
      ${openbao_service_ip} ${openbao_service_fqdn} openbao
      ${local_mirror_service_ip} ${local_mirror_service_fqdn} local-mirror
